{
  "name": "infllax-theater-client",
  "version": "1.0.0",
  "description": "Infllax DCMS — Theater Client App (Electron.js)",
  "main": "src/main/main.js",
  "scripts": {
    "start":  "electron .",
    "dev":    "NODE_ENV=development electron .",
    "build":  "electron-builder",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5",
    "electron-store":   "^8.2.0"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.infllax.dcms-theater",
    "productName": "Infllax Theater Client",
    "win": {
      "target": ["nsis"],
      "icon":   "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon":   "assets/icon.png"
    }
  }
}
